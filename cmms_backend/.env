# ─── Application ─────────────────────────────────────────────────────────────
APP_ENV=development          # development | staging | production
APP_SECRET_KEY=change-me-to-a-random-64-char-string
LOG_LEVEL=INFO

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=rtknits_cmms
POSTGRES_USER=cmms_user
POSTGRES_PASSWORD=supersecret
# Async DSN used by SQLAlchemy
DATABASE_URL=postgresql+asyncpg://cmms_user:supersecret@localhost:5432/rtknits_cmms
# Sync DSN used by Alembic
DATABASE_URL_SYNC=postgresql://cmms_user:supersecret@localhost:5432/rtknits_cmms

# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o            # vision + text + function-calling in one model
OPENAI_WHISPER_MODEL=whisper-1
OPENAI_TEMPERATURE=0.2
OPENAI_MAX_TOKENS=1024

# ─── Meta WhatsApp Cloud API ──────────────────────────────────────────────────
WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token
WHATSAPP_ACCESS_TOKEN=your-meta-permanent-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_API_VERSION=v19.0
WHATSAPP_API_BASE=https://graph.facebook.com

# ─── ChromaDB (vector store for Knowledge Agent) ─────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION=rtknits_knowledge

# ─── APScheduler ──────────────────────────────────────────────────────────────
NIGHTLY_PLAN_HOUR=21           # 9 PM — generate tomorrow's plan
NIGHTLY_PLAN_MINUTE=0
TIMEZONE=Indian/Mauritius      # UTC+4

# ─── P0 Escalation ───────────────────────────────────────────────────────────
P0_ESCALATION_MINUTES=5        # minutes before re-routing unacknowledged P0

# ─── Seed Data ────────────────────────────────────────────────────────────────
SEED_DATA_DIR=data/            # folder containing Assets.xlsx, Tasks.xlsx, Technicians.xlsx
